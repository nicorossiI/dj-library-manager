# .env.example
# Copia in .env e compila con le tue chiavi ACRCloud.
# NOTA: il file .env è usato SOLO in sviluppo (npm start).
# In produzione l'utente inserisce le chiavi dalle Impostazioni dell'app,
# che vengono salvate in %APPDATA%/dj-library-manager/config.json tramite electron-store.

# Nuovi nomi (preferiti — spec CONFIG.acr)
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_KEY=
ACR_SECRET=

# Alias legacy (ancora letti da CONFIG.js come fallback)
# ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
# ACRCLOUD_ACCESS_KEY=
# ACRCLOUD_ACCESS_SECRET=
